{
    /* basic fixes and disables */
    "update.mode": "none", // disable automatic updates
    "github.copilot.enable": { "*": false, },
    "telemetry.telemetryLevel": "off",
    "git.openRepositoryInParentFolders": "never",
    "security.workspace.trust.untrustedFiles": "open",
    "debug.openDebug": "neverOpen",
    "debug.internalConsoleOptions": "neverOpen",
    "git.confirmSync": false,
    "explorer.confirmDelete": false,
    "editor.mouseWheelZoom": true,
    "editor.wordWrap": "off",
    "editor.accessibilitySupport": "off",
    "terminal.integrated.mouseWheelZoom": true,
    "C_Cpp.intelliSenseEngine": "disabled",

    /* disable the menu bar */
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,
    "window.menuBarVisibility": "compact",

    /* code autocomplete */
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingQuotes": "always",
    "files.trimTrailingWhitespace": true,

    /*  vscode-vim */
    "vim.autoindent": true,
    "vim.leader": " ",
    "vim.vimrc.enable": true,
    "vim.hlsearch": true,
    "vim.overrideCopy": true,

    // plugins
    "vim.easymotion": true,
    "vim.surround": true,

    // some quality-of-life improvements
    "vim.camelCaseMotion.enable": true,
    "vim.changeWordIncludesWhitespace": false,
    "vim.foldfix": true,
    "vim.mouseSelectionGoesIntoVisualMode": true,
    "vim.handleKeys": {
        "<C-k>": false,
        "<C-p>": false,
        "<C-o>": true,
        "<C-b>": false,
        "<C-f>": false,
        "<C-w>": false,
        "<C-t>": false,
        "<C-q>": true,
    },

    /* language-specific settings */
    "[markdown]": { "editor.defaultFormatter": "DavidAnson.vscode-markdownlint" },
    "[c]": {
        "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: LLVM, IndentWidth: 4, BreakBeforeBraces: Linux, AllowShortIfStatementsOnASingleLine: false, IndentCaseLabels: false}",
    },
    "testMate.cpp.debug.configTemplate": {
    "type": "cppvsdbg",
    "linux": { "type": "cppdbg", "MIMode": "gdb" },
    "darwin": { "type": "cppdbg", "MIMode": "lldb" },
    "win32": { "type": "cppvsdbg" },
    "program": "${exec}",
    "args": "${argsArray}",
    "cwd": "${cwd}",
    "env": "${envObj}",
    "environment": "${envObjArray}",
    "sourceFileMap": "${sourceFileMapObj}",
    },

    /* appearance */
    "workbench.colorTheme": "Visual Studio 2017 Light - C++",
    "cline-sr.viewScale": "75%",
    "editor.rulers": [80, 100, 120],
    "editor.minimap.enabled": false,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
        { "scope": "heading.1.markdown entity.name.section.markdown, heading.1.markdown punctuation.definition.heading.markdown",
            "settings": { "foreground": "#0366d6", "fontStyle": "bold", } },
        { "scope": "heading.2.markdown entity.name.section.markdown, heading.2.markdown punctuation.definition.heading.markdown",
            "settings": { "foreground": "#5a32a3", } },
        { "scope": "heading.3.markdown entity.name.section.markdown, heading.3.markdown punctuation.definition.heading.markdown",
            "settings": { "foreground": "#0598bc", } }
        ]
    },

    /* misc plugins and utils*/
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.env.linux": { "CODE": "1" },
    "terminal.integrated.defaultProfile.windows": "cmd",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.stickyScroll.enabled": false,
    "explorer.confirmDragAndDrop": false,

    /* prevent shell from capturing some of the keybindings */
    "terminal.integrated.commandsToSkipShell": [
        "workbench.action.toggleSidebarVisibility",
        "workbench.action.toggleActivityBarVisibility",
        "workbench.explorer.fileView.focus",
        "workbench.action.quickOpenTerm",
        "workbench.action.terminal.rename",
        "workbench.action.nextEditor",
        "workbench.action.previousEditor",
        "workbench.action.increaseViewSize",
        "workbench.action.decreaseViewSize",
        "workbench.action.debug.start",
        "workbench.action.debug.run",
        "workbench.action.debug.restart",
        "workbench.action.debug.stop",
        "workbench.action.debug.disconnect",
        "workbench.action.debug.notebook.cell.output.selectAll",
        "matlab.interrupt"
    ],

    /* extensions */
    "settingsSync.ignoredExtensions": [
        "ms-vscode-remote.remote-wsl",
        "ms-vscode.remote-explorer",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.remote-ssh-edit"
    ],
    "editor.inlayHints.enabled": "offUnlessPressed", // ctrl-alt to show hints
    "C_Cpp.clang_format_fallbackStyle": "LLVM",
    "workbench.editor.empty.hint": "hidden",
    "workbench.startupEditor": "none",
    "terminal.integrated.fontSize": 12,
    "editor.fontSize": 11,

    /* SSH */
    "remote.SSH.path": "C:\\Windows\\System32\\OpenSSH\\ssh.exe",
    "remote.SSH.remotePlatform": {
        "106.120.250.186": "linux",
        "106.120.77.92": "linux"
    },

    /* new */
}
